@model List<Beneficiary>
<h2>Beneficiaries</h2><div class="row"><div class="col-md-5"><div class="card p-3"><form method="post" action="/Transaction/AddBeneficiary"><input name="NickName" class="form-control mb-2" placeholder="Nick name"><input name="AccountNumber" class="form-control mb-2" placeholder="Account number"><button class="btn btn-primary">Add</button></form></div></div><div class="col-md-7"><table class="table"><tr><th>Name</th><th>Account</th></tr>@foreach(var b in Model){<tr><td>@b.NickName</td><td>@b.AccountNumber</td></tr>}</table></div></div>