@model List<Transaction>
<h2>Transaction History</h2><form class="row g-2 mb-3"><div class="col"><input type="date" name="fromDate" class="form-control"></div><div class="col"><input type="date" name="toDate" class="form-control"></div><div class="col"><button class="btn btn-primary">Filter</button></div></form><div class="card p-3"><table class="table table-striped"><tr><th>Date</th><th>From</th><th>To</th><th>Amount</th><th>Type</th><th>Remarks</th></tr>@foreach(var t in Model){<tr><td>@t.Date.ToString("dd-MMM-yyyy HH:mm")</td><td>@t.FromAccount</td><td>@t.ToAccount</td><td>₹@t.Amount</td><td>@t.Type</td><td>@t.Remarks</td></tr>}</table></div>