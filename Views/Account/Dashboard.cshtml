@model List<Account>
<h2>Account Dashboard</h2><div class="row g-3 mb-4"><div class="col-md-4"><div class="card p-3 stat"><b>Total Balance</b><h3>₹@Model.Sum(x=>x.Balance)</h3></div></div><div class="col-md-4"><div class="card p-3 stat"><b>Transactions</b><h3>@ViewBag.TotalTransactions</h3></div></div><div class="col-md-4"><div class="card p-3 stat"><b>Pending Loans</b><h3>@ViewBag.PendingLoans</h3></div></div></div><div class="card p-3"><h5>My Accounts</h5><table class="table"><tr><th>Account No</th><th>Type</th><th>Balance</th><th>Status</th><th></th></tr>@foreach(var a in Model){<tr><td>@a.AccountNumber</td><td>@a.AccountType</td><td>₹@a.Balance</td><td>@(a.IsActive?"Active":"Closed")</td><td><form method="post" action="/Account/CloseAccount"><input type="hidden" name="id" value="@a.AccountId"><button class="btn btn-sm btn-outline-danger">Close</button></form></td></tr>}</table><form method="post" action="/Account/OpenAccount" class="d-flex gap-2"><select name="accountType" class="form-select w-auto"><option>Savings</option><option>Current</option></select><button class="btn btn-primary">Open Account</button></form></div>