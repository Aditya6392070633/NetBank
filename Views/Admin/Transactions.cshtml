@model List<Transaction>
<h2>All Transactions</h2><table class="table table-striped"><tr><th>Date</th><th>From</th><th>To</th><th>Amount</th><th>Remarks</th></tr>@foreach(var t in Model){<tr><td>@t.Date</td><td>@t.FromAccount</td><td>@t.ToAccount</td><td>₹@t.Amount</td><td>@t.Remarks</td></tr>}</table>