@model List<Loan>
<h2>Loan Approval</h2><table class="table"><tr><th>User</th><th>Amount</th><th>Status</th><th>Action</th></tr>@foreach(var l in Model){<tr><td>@l.User?.Name</td><td>₹@l.Amount</td><td>@l.Status</td><td><form method="post" action="/Admin/UpdateLoan" class="d-flex gap-1"><input type="hidden" name="id" value="@l.LoanId"><button name="status" value="Approved" class="btn btn-sm btn-success">Approve</button><button name="status" value="Rejected" class="btn btn-sm btn-danger">Reject</button></form></td></tr>}</table>