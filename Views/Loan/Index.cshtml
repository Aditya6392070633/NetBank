@model List<Loan>
<h2>Loan Applications</h2><div class="card p-3 mb-3"><form method="post" action="/Loan/Apply" class="d-flex gap-2"><input name="amount" type="number" class="form-control" placeholder="Loan amount"><button class="btn btn-success">Apply</button></form></div><table class="table"><tr><th>ID</th><th>Amount</th><th>Interest</th><th>Status</th><th>Date</th></tr>@foreach(var l in Model){<tr><td>@l.LoanId</td><td>₹@l.Amount</td><td>@l.InterestRate%</td><td><span class="badge bg-secondary">@l.Status</span></td><td>@l.AppliedOn.ToString("dd-MMM-yyyy")</td></tr>}</table>